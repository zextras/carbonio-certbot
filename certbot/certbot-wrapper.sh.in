# python version
pyver=pythonPYTHON_VERSION

# set proper modules path
PYTHONPATH="/opt/zextras/common/certbot/lib/${pyver}/dist-packages:"
PYTHONPATH+="/opt/zextras/common/certbot/lib/${pyver}/site-packages:"
PYTHONPATH+="/opt/zextras/common/certbot/lib64/${pyver}/dist-packages:"
PYTHONPATH+="/opt/zextras/common/certbot/lib64/${pyver}/site-packages:"
PYTHONPATH+="/opt/zextras/common/certbot/local/lib/${pyver}/dist-packages:"
PYTHONPATH+="/opt/zextras/common/certbot/local/lib/${pyver}/site-packages:"
PYTHONPATH+="/opt/zextras/common/certbot/local/lib64/${pyver}/dist-packages:"
PYTHONPATH+="/opt/zextras/common/certbot/local/lib64/${pyver}/site-packages:"
export PYTHONPATH

# main certbot entrypoint with args
/opt/zextras/common/certbot/bin/carbonio-certbot "${@}"
