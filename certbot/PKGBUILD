pkgname="carbonio-certbot"
pkgver="2.3.0"
pkgrel="3"
pkgdesc="An ACME client for Carbonio"
maintainer="Zextras <packages@zextras.com>"
url="https://www.zextras.com/"
section="admin"
priority="optional"
arch=('x86_64')
license=("Apache")

depends=(
  "python3"
  "python3-setuptools"
)
depends_rocky_8=(
  "python38"
  "python38-setuptools"
)
makedepends__apt=(
  "python3-pkg-resources"
  "python3-pip"
)
makedepends__yum=(
  "python3-pip"
)
makedepends__rocky_8=(
  "python38-pip"
)

source=(
  "carbonio-paths.patch"
  "certbot-wrapper.sh"
  "certbot-renew.service"
  "certbot-renew.timer"
  "tmpfiles.conf"
)
sha256sums=('5482e89a6fbe724dd6e3a88308edda8e475d1234534a7fe6187cd8b8ce5acb21'
  '01ad5a09ba1a8d11a42bf19a96e773884565c3b8dada9d176f6531cef0a6e7aa'
  '6d81a62d0a6585487f5a72e3270e1fe12ab9555e2b34928ac850789b3b2ff94a'
  '49897471771049ec94ba1b0f56d6252d9c124dbe16ff4b9310e695f1fa0ce794'
  'd5f0babf32898394183f557bb40291ad0d3d9b9e03202ccbf2342db35d8ac8b1')

build() {
  pip3 install \
    certbot=="${pkgver}" \
    --prefix="${pkgdir}/opt/zextras/common/certbot"
}

package() {
  install -Dm644 "${srcdir}/certbot-renew.service" \
    "${pkgdir}/lib/systemd/system/${pkgname}.service"

  install -Dm644 "${srcdir}/certbot-renew.timer" \
    "${pkgdir}/lib/systemd/system/${pkgname}.timer"

  install -Dm644 "${srcdir}/tmpfiles.conf" \
    "${pkgdir}/lib/tmpfiles.d/${pkgname}.conf"

  install -Ddm755 "${pkgdir}/var/log/carbonio/letsencrypt/"
  install -Ddm755 "${pkgdir}/opt/zextras/.well-known/acme-challenge"

  # on some distros, prefix is concatenated to local and immutable by default
  # let's normalize this prefix path
  if [ -d "${pkgdir}/opt/zextras/common/certbot/local" ]; then
    mv "${pkgdir}/opt/zextras/common/certbot/local/"* \
      "${pkgdir}/opt/zextras/common/certbot/"
    rm -rf "${pkgdir}/opt/zextras/common/certbot/local"
  fi

  # to set proper PYTHONPATH we need a little bash wrapper
  # we move official executable to carbonio-certbot ...
  mv "${pkgdir}/opt/zextras/common/certbot/bin/certbot" \
    "${pkgdir}/opt/zextras/common/certbot/bin/carbonio-certbot"

  # ... after we rename the wrapper as certbot
  install -Dm755 "${srcdir}/certbot-wrapper.sh" \
    "${pkgdir}/opt/zextras/common/bin/certbot"

  # Remove generated bytecode
  find "${pkgdir}" -iname "*.pyc" -exec rm {} \;
  # Remove conflict with preview python resources
  rm "${pkgdir}"/opt/zextras/common/certbot/bin/normalizer

  # Apply custom paths
  cd $(find ${pkgdir} -name "misc.py" | xargs dirname)
  patch -Np1 -i "${srcdir}/carbonio-paths.patch"
}

postinst() {
  getent group 'zextras' >/dev/null ||
    groupadd -r 'zextras'
  getent passwd 'zextras' >/dev/null ||
    useradd -r -M -d '/opt/zextras' -g 'zextras' -s /bin/bash 'zextras'

  systemd-tmpfiles --create carbonio-certbot.conf >/dev/null || true
}
