_pyver_rocky_8="3.11"
_pyver_rocky_9="3.11"
_pyver_ubuntu_jammy="3.10"
_pyver_ubuntu_noble="3.12"

pkgname="carbonio-certbot"
pkgver="5.7.0" # renovate: datasource=pypi depName=certbot
pkgrel="1"
pkgdesc="An ACME client for Carbonio"
maintainer="Zextras <packages@zextras.com>"
url="https://www.zextras.com/"
section="admin"
priority="optional"
arch=('x86_64')
license=('Apache-2.0 AND MIT')

depends=(
  "carbonio-core"
  "python3"
  "python3-setuptools"
)
depends__rocky_8=(
  "carbonio-core"
  "python${_pyver_rocky_8}"
  "python${_pyver_rocky_8}-setuptools"
)
depends__rocky_9=(
  "carbonio-core"
  "python${_pyver_rocky_9}"
  "python${_pyver_rocky_9}-setuptools"
)
makedepends__apt=(
  "python3-pkg-resources"
  "python3-pip"
)
makedepends__rocky_8=(
  "python${_pyver_rocky_8}-pip"
)
makedepends__rocky_9=(
  "python${_pyver_rocky_9}-pip"
)

source=(
  "carbonio-paths.patch"
  "systemd-tmpfile.conf"
  "certbot-renew.service"
  "certbot-renew.timer"
  "certbot-wrapper.sh.in"
)
sha256sums=(
  'c9a5b5e096a12e414351e9534280e1e761a71590eb1f58f27c82efd6f87cf408'
  'e22053897ea862919763bc39f44bbf45e07c1c940082752168359990d2ceee14'
  '318fa71354a92483943863631fc5733e86d410fe5f020eca0bbfb0841e360bfc'
  'ee6fb7df85508c1b2bf9b83dd46b19031421aca466c1c5906a14f650b11721a8'
  '33e932e9065a1ba432efd4e1819897013369ccdcbacc95525c3f69dbf605dff6'
)

build__rocky_8() {
  "pip${_pyver_rocky_8}" install \
    --only-binary cryptography \
    certbot=="${pkgver}" \
    --prefix="${pkgdir}/opt/zextras/common/certbot"

  install -Dm755 "${srcdir}/certbot-wrapper.sh.in" \
    "${pkgdir}/opt/zextras/common/bin/certbot"

  sed -i "s/PYTHON_VERSION/${_pyver_rocky_8}/g" \
    "${pkgdir}/opt/zextras/common/bin/certbot"
}

build__rocky_9() {
  "pip${_pyver_rocky_9}" install \
    --only-binary cryptography \
    certbot=="${pkgver}" \
    --prefix="${pkgdir}/opt/zextras/common/certbot"

  install -Dm755 "${srcdir}/certbot-wrapper.sh.in" \
    "${pkgdir}/opt/zextras/common/bin/certbot"

  sed -i "s/PYTHON_VERSION/${_pyver_rocky_9}/g" \
    "${pkgdir}/opt/zextras/common/bin/certbot"
