targets=(
   "centos"
   "ubuntu"
)
pkgname="carbonio-certbot"
pkgver="2.2.0"
pkgrel="1"
pkgdesc="An ACME client for Carbonio"
pkgdesclong=(
  "An ACME client for Carbonio"
)
maintainer="Zextras <packages@zextras.com>"
url="https://www.zextras.com/"
section="admin"
priority="optional"
arch="amd64"
license=("Apache")

makedepends:apt=(
  "python3-pkg-resources"
  "python3-pip"
)

makedepends:yum=(
  "python38-pip"
)

sources=(
  "${pkgname}.spec"
  "${pkgname}-paths.patch"
  "${pkgname}-pyinstaller.patch"
  "${pkgname}-renew.service"
  "${pkgname}-renew.timer"
  "tmpfiles.conf"
)
hashsums=(
  "skip"
  "skip"
  "skip"
  "skip"
  "skip"
  "skip"
)

build() {
  cd "${srcdir}"

  # needed for rhel (/usr/local/bin is not in PATH)
  export PATH="/usr/local/bin:$PATH"
  # virtualenv enablement
  pip3 install virtualenv
  virtualenv .
  . bin/activate

  pip3 install \
    certbot=="${pkgver}"

  # Apply pyinstaller patch
  patch -Np1 -i "${srcdir}/${pkgname}-pyinstaller.patch"

  # Apply custom paths
  patch -Np1 -i "${srcdir}/${pkgname}-paths.patch"


  # required components before pyinstaller processing
  pip3 install pyinstaller

  # pyinstaller bundle creation
  pyinstaller "${pkgname}.spec"
}

package() {
  install -Dm755 "${srcdir}/dist/certbot" \
    "${pkgdir}/opt/zextras/common/bin/certbot"

  install -Dm644 "${srcdir}/${pkgname}-renew.service" \
    "${pkgdir}/lib/systemd/system/${pkgname}.service"

  install -Dm644 "${srcdir}/${pkgname}-renew.timer" \
    "${pkgdir}/lib/systemd/system/${pkgname}.timer"

  install -Dm644 "${srcdir}/tmpfiles.conf" \
    "${pkgdir}/lib/tmpfiles.d/${pkgname}.conf"

  install -Ddm755 "${pkgdir}/var/log/carbonio/letsencrypt/"
  install -Ddm755 "${pkgdir}/opt/zextras/.well-known/acme-challenge"
}

postinst() {
  systemd-tmpfiles --create "${pkgname}.conf" >/dev/null || true
}
